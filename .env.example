# Convex (powers the private /app learning area)
# Run `bun run dev:convex` once; it provisions a deployment. Copy the deployment
# URL here. PUBLIC_ is Astro's client-exposed prefix; this URL is safe to expose
# (the browser talks to the deployment directly, data is guarded server-side).
PUBLIC_CONVEX_URL=

# Convex deploy key — used ONLY by scripts/teach-sync.ts to push learning
# workspaces from your laptop. Secret; never commit. Get it from the Convex
# dashboard (Settings → Deploy Keys) or the .env.local convex writes.
CONVEX_DEPLOY_KEY=

# PostHog
VITE_POSTHOG_PROJECT_TOKEN=
VITE_POSTHOG_HOST=https://us.i.posthog.com
