---
import {experience} from '@/data/experience'
---

<div class="timeline">
  {
    experience.map((item) => (
      <article class="timeline-item">
        <div class="timeline-meta">
          <strong>{item.dates}</strong>
          {item.location && <div>{item.location}</div>}
        </div>
        <div>
          <p class="meta-label">{item.company}</p>
          <h3>{item.role}</h3>
          {item.summary && <p>{item.summary}</p>}
          {item.bullets.length > 0 && (
            <ul>
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          )}
          {item.subRoles?.map((subRole) => (
            <section class="sub-role">
              <p class="meta-label">{subRole.dates}{subRole.tech ? ` · ${subRole.tech}` : ''}</p>
              <h3>{subRole.role}</h3>
              <ul>
                {subRole.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </section>
          ))}
        </div>
      </article>
    ))
  }
</div>
