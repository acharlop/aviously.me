---
// Minimal shell for the private /app learning area. Deliberately excludes the
// portfolio Header/Footer, analytics, and SEO/JSON-LD, and is marked noindex —
// this area is private and must never be indexed or appear in the sitemap.
import '@/styles/global.css'

type Props = {title?: string}
const {title = 'Learning'} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · aviously</title>
    <link rel="icon" href="/favicon.png" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
  }
</style>

<!-- Typography for rendered markdown fields (mission, learning records). Scoped
     to .md-body so these beat the site's large unlayered h1/h2/h3 rules. -->
<style is:global>
  .md-body {
    line-height: 1.6;
  }
  .md-body > :first-child {
    margin-top: 0;
  }
  .md-body h1,
  .md-body h2,
  .md-body h3,
  .md-body h4 {
    font-family: var(--font-body);
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
    margin: 1.4em 0 0.5em;
    letter-spacing: normal;
  }
  .md-body h1 {
    font-size: 1.25rem;
  }
  .md-body h2 {
    font-size: 1.05rem;
  }
  .md-body h3,
  .md-body h4 {
    font-size: 0.95rem;
  }
  .md-body p,
  .md-body ul,
  .md-body ol {
    margin: 0.6em 0;
  }
  .md-body ul,
  .md-body ol {
    padding-left: 1.4em;
  }
  .md-body ul {
    list-style: disc;
  }
  .md-body ol {
    list-style: decimal;
  }
  .md-body li {
    margin: 0.25em 0;
  }
  .md-body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .md-body strong {
    color: var(--text);
    font-weight: 600;
  }
  .md-body code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-2);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }
  .md-body pre {
    background: var(--bg-2);
    padding: 0.8em 1em;
    border-radius: 6px;
    overflow-x: auto;
  }
  .md-body pre code {
    background: none;
    padding: 0;
  }
  .md-body blockquote {
    margin: 0.8em 0;
    padding-left: 1em;
    border-left: 2px solid var(--line);
    color: var(--faint);
  }
</style>
