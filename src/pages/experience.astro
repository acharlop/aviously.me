---
import ExperienceTimeline from '@/components/ExperienceTimeline.astro'
import Layout from '@/components/Layout.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import {education} from '@/data/experience'
---

<Layout title="Experience - Avi Charlop" description="Resume-style timeline for Avi Charlop, senior full-stack engineer and team lead.">
  <section class="shell page-hero">
    <p class="eyebrow">`experience`</p>
    <h1>A timeline of product systems, modernization, and team leadership.</h1>
    <p class="lead">Canonical resume data for recent roles, selected freelance work, education, and long-running platform experience.</p>
  </section>

  <section class="shell section">
    <SectionHeading kicker="timeline" title="Professional experience" />
    <ExperienceTimeline />
  </section>

  <section class="shell section">
    <SectionHeading kicker="education" title="Education" />
    <div class="grid-2">
      {education.map((item) => (
        <article class="card">
          <p class="meta-label">{item.dates} · {item.location}</p>
          <h3>{item.school}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
