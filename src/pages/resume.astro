---
import fs from 'node:fs'
import ExperienceTimeline from '@/components/ExperienceTimeline.astro'
import Layout from '@/components/Layout.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import {shapeResume} from '@/lib/resume-export'
import {skills} from '@/data/experience'
import {site} from '@/data/site'

// The crawl test fetches every linked PDF, so only offer the download once the file is committed.
const hasPdf = fs.existsSync('public/resume.pdf')
const {experience, education} = shapeResume()
---

<Layout title="Resume - Avi Charlop" description="Resume of Avi Charlop, senior full-stack engineer and team lead: experience, education, and a downloadable PDF.">
  <section class="shell page-hero">
    <p class="eyebrow">`resume`</p>
    <h1>{site.name}</h1>
    <p class="lead">{site.tagline}</p>
    <p class="print-contact meta-label">
      {site.email} · {site.url.replace('https://', '')} · {site.linkedin.replace('https://', '')} · {site.github.replace('https://', '')}
    </p>
    <div class="button-row print-hidden">
      {hasPdf && <a class="button" href="/resume.pdf" download>Download PDF</a>}
      <button class="button secondary" type="button" onclick="window.print()">Print this page</button>
      <a class="button secondary" href={`mailto:${site.email}`}>{site.email}</a>
    </div>
    <p class="meta-label print-hidden">
      also as <a href="/resume.md">markdown</a> · <a href="/resume.txt">plain text</a> ·
      <a href="/resume.json">json resume</a>
    </p>
  </section>

  <section class="shell section">
    <SectionHeading kicker="skills" title="Skills" />
    <dl class="skills-grid">
      {
        skills.map((group) => (
          <div class="skills-row">
            <dt>{group.name}</dt>
            <dd>{group.keywords.join(', ')}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section class="shell section">
    <SectionHeading kicker="timeline" title="Professional experience" />
    <ExperienceTimeline items={experience} />
  </section>

  {
    education.length > 0 && (
      <section class="shell section education-section">
        <SectionHeading kicker="education" title="Education" />
        <div class="grid-2">
          {education.map((item) => (
            <article class="card">
              <p class="meta-label">
                {item.dates} · {item.location}
              </p>
              <h3>{item.school}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </section>
    )
  }
</Layout>

<style>
  .skills-grid {
    display: grid;
    gap: 8px;
    margin: 0;
  }

  .skills-row {
    display: grid;
    grid-template-columns: minmax(120px, 160px) 1fr;
    gap: 12px;
    align-items: baseline;
  }

  .skills-row dt {
    font-weight: 600;
  }

  .skills-row dd {
    margin: 0;
  }

  @media (max-width: 480px) {
    .skills-row {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }

  .print-contact {
    display: none;
  }

  @media print {
    .print-hidden {
      display: none;
    }

    .print-contact {
      display: block;
      margin-top: 4px;
    }
  }
</style>

<style is:global>
  @media print {
    header.site-header,
    footer,
    .skip-link {
      display: none !important;
    }

    html,
    body {
      background: #fff !important;
    }

    html {
      font-size: 0.78rem;
    }

    body::before {
      display: none !important;
    }

    .page-hero {
      padding: 0 0 8px;
    }

    .page-hero h1 {
      font-size: 2rem;
    }

    .section {
      padding: 14px 0;
    }

    .section-head {
      margin-bottom: 10px;
    }

    .section-head h2 {
      font-size: 1.4rem;
    }

    .timeline {
      gap: 10px;
    }

    .timeline-item,
    .card {
      background: #fff !important;
      box-shadow: none !important;
      break-inside: avoid;
    }

    .timeline-item {
      grid-template-columns: 150px minmax(0, 1fr);
      gap: 14px;
      padding: 12px 14px;
    }

    .timeline-item ul {
      margin-top: 8px;
    }

    .timeline-item li + li {
      margin-top: 4px;
    }

    .sub-role {
      margin-top: 10px;
      padding-top: 10px;
      break-inside: avoid;
    }

    .education-section {
      break-inside: avoid;
    }
  }
</style>
